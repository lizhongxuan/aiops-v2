{
  "id": "role-conflict-blocks-mutation",
  "category": "multi_agent_assembly",
  "priority": "P0",
  "input": "@hostA 设置为 PG 主节点，工具证据又显示 @hostB 也是 PG 主节点；现在把主节点切换到 hostA。",
  "expected": {
    "mustNotInclude": ["promote executed", "mutation completed"],
    "expectedAssembly": {
      "agentKind": "verifier",
      "profile": "verifier.default",
      "runtimeRole": "profile_only",
      "routeReasonContains": "role_conflict"
    },
    "expectedResources": {
      "verifiedIds": ["hostA", "hostB"]
    },
    "expectedRoleBindings": [
      {
        "resourceId": "hostA",
        "role": "pg_primary",
        "conflictState": "role_conflict"
      }
    ],
    "expectedToolSurface": {
      "visibleTools": ["read_evidence"],
      "dispatchableTools": ["read_evidence"],
      "hiddenTools": ["exec_command"],
      "requireSingleSource": true
    },
    "expectedTraceExplainability": {
      "requireAssemblySource": true,
      "requirePromptCompilerSource": true,
      "requireToolSurfaceSource": true,
      "requireAdapterName": true,
      "requirePromptSectionHashes": true,
      "requireToolSurfaceFingerprint": true
    }
  }
}
