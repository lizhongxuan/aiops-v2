    "strict": false
  },
  "include": [
    "src/transport/aiopsTransportTypes.ts",
    "src/transport/aiopsTransportRuntime.ts",
    "src/transport/aiopsTransportStateCache.ts",
    "src/chat/components/OpsRunSummaryCard.tsx",
    "src/chat/components/ProcessTranscript.tsx",
    "src/chat/components/TaskChecklistCard.tsx",
    "src/chat/components/ToolBlockPart.tsx",
    "src/chat/components/ProcessBlockPart.tsx",
    "src/chat/components/ApprovalBlockPart.tsx",
    "src/chat/components/MessageMarkdown.tsx",
